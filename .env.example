# ──────────────────────────────────────────────
# PrivacyAware-PenAgent  —  Environment Config
# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── LLM Provider Keys ───────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OLLAMA_HOST=http://localhost:11434

# ── Metasploit RPC ──────────────────────────
MSF_RPC_HOST=127.0.0.1
MSF_RPC_PORT=55553
MSF_RPC_PASSWORD=changeme

# ── Privacy / Sensitivity Controls ──────────
# Float 0.0–1.0: data sensitivity above this routes to CLOUD
SENSITIVITY_THRESHOLD=0.6
# Float 0.0–1.0: task complexity above this routes to CLOUD
COMPLEXITY_THRESHOLD=0.7

# ── Rate Limits ─────────────────────────────
MAX_CLOUD_TOKENS_PER_RUN=50000
MAX_EXPLOIT_RETRIES=3

# ── Logging ─────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
